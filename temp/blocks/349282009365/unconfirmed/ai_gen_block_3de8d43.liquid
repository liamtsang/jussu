{% doc %}
  @prompt
    a small icon that leads to a link, I want to use my own image and the icon should be located in the right side of the mobile site and in the middle
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-icon-link-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-icon-link-container-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
  }

  @media screen and (max-width: 749px) {
    .ai-icon-link-container-{{ ai_gen_id }} {
      justify-content: flex-end;
      padding-right: {{ block.settings.mobile_padding_right }}px;
    }
  }

  .ai-icon-link-wrapper-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    transition: all 0.3s ease;
    text-decoration: none;
    overflow: hidden;
  }

  .ai-icon-link-wrapper-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.hover_background_color }};
    transform: scale({{ block.settings.hover_scale }});
  }

  .ai-icon-link-wrapper-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.icon_size }}px * 0.5);
    height: calc({{ block.settings.icon_size }}px * 0.5);
    fill: {{ block.settings.icon_color }};
    transition: fill 0.3s ease;
  }

  .ai-icon-link-wrapper-{{ ai_gen_id }}:hover svg {
    fill: {{ block.settings.hover_icon_color }};
  }

  .ai-icon-link-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-icon-link-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-icon-link-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    fill: #cccccc;
  }
{% endstyle %}

<icon-link-{{ ai_gen_id }} class="ai-icon-link-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-icon-link-container-{{ ai_gen_id }}">
    <a
      href="{{ block.settings.link_url }}"
      class="ai-icon-link-wrapper-{{ ai_gen_id }}"
      aria-label="{{ block.settings.aria_label }}"
      {% if block.settings.open_in_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
    >
      {% if block.settings.use_custom_image %}
        {% if block.settings.custom_image %}
          <img
            src="{{ block.settings.custom_image | image_url: width: 200 }}"
            alt="{{ block.settings.custom_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.icon_size }}"
            height="{{ block.settings.icon_size }}"
          >
        {% else %}
          <div class="ai-icon-link-image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      {% else %}
        {% case block.settings.icon_type %}
          {% when 'home' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
            </svg>
          {% when 'search' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
            </svg>
          {% when 'cart' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49A1.003 1.003 0 0 0 20 4H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z"/>
            </svg>
          {% when 'user' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
            </svg>
          {% when 'heart' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
            </svg>
          {% when 'menu' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"/>
            </svg>
          {% when 'arrow_right' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/>
            </svg>
          {% when 'arrow_left' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/>
            </svg>
          {% when 'close' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
            </svg>
          {% when 'email' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
            </svg>
          {% when 'phone' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
            </svg>
          {% when 'info' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/>
            </svg>
          {% when 'star' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
            </svg>
        {% endcase %}
      {% endif %}
    </a>
  </div>
</icon-link-{{ ai_gen_id }}>

<script>
  (function() {
    class IconLink{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }

    customElements.define('icon-link-{{ ai_gen_id }}', IconLink{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Icon link",
  "settings": [
    {
      "type": "header",
      "content": "Link"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "Accessibility label",
      "default": "Icon link"
    },
    {
      "type": "checkbox",
      "id": "open_in_new_tab",
      "label": "Open in new tab",
      "default": false
    },
    {
      "type": "header",
      "content": "Icon"
    },
    {
      "type": "checkbox",
      "id": "use_custom_image",
      "label": "Use custom image",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "custom_image",
      "label": "Custom image"
    },
    {
      "type": "select",
      "id": "icon_type",
      "label": "Icon type",
      "options": [
        {
          "value": "home",
          "label": "Home"
        },
        {
          "value": "search",
          "label": "Search"
        },
        {
          "value": "cart",
          "label": "Cart"
        },
        {
          "value": "user",
          "label": "User"
        },
        {
          "value": "heart",
          "label": "Heart"
        },
        {
          "value": "menu",
          "label": "Menu"
        },
        {
          "value": "arrow_right",
          "label": "Arrow right"
        },
        {
          "value": "arrow_left",
          "label": "Arrow left"
        },
        {
          "value": "close",
          "label": "Close"
        },
        {
          "value": "email",
          "label": "Email"
        },
        {
          "value": "phone",
          "label": "Phone"
        },
        {
          "value": "info",
          "label": "Info"
        },
        {
          "value": "star",
          "label": "Star"
        }
      ],
      "default": "home"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "hover_icon_color",
      "label": "Hover icon color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Position"
    },
    {
      "type": "range",
      "id": "mobile_padding_right",
      "label": "Mobile right spacing",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "hover_background_color",
      "label": "Hover background color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "hover_scale",
      "label": "Hover scale",
      "min": 1,
      "max": 1.5,
      "step": 0.1,
      "default": 1.1
    }
  ],
  "presets": [
    {
      "name": "Icon link"
    }
  ]
}
{% endschema %}
